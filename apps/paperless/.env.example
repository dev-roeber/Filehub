# Paperless-ngx app-spezifische Variablen.
# Reale Werte gehoeren in das Root-.env (gitignored).
PAPERLESS_PORT=8000
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=<set-local-secret>
PAPERLESS_SECRET_KEY=<set-local-secret>
PAPERLESS_ADMIN_USER=${FILEHUB_ADMIN_USER:-admin}
PAPERLESS_ADMIN_PASSWORD=<set-local-secret>
