# Whisper-ASR (OpenAI Whisper Speech-to-Text Webservice).
# CPU-Variante - keine GPU/CUDA noetig. Modelle werden beim ersten Start
# nach /root/.cache/whisper heruntergeladen (mehrere GB je nach Modell).
WHISPER_ASR_PORT=9001
WHISPER_ASR_IMAGE=onerahmet/openai-whisper-asr-webservice:v1.7.0
WHISPER_ASR_MODEL=base
WHISPER_ASR_ENGINE=openai_whisper
# Healthcheck Grace Period (an Modellgroesse anpassen):
#   tiny/base 60s, small 120s, medium 300s, large 600s
WHISPER_ASR_START_PERIOD=120s
