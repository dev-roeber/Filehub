# Caddy reverse_proxy snippet fuer Whisper-ASR (DEAKTIVIERT).
# Aktivierung: Datei zu .caddy umbenennen UND im Gateway-Caddyfile via
# `import apps/whisper-asr/caddy` einbinden (oder Inhalt per handle einbetten).
# Standardmaessig wird dieses Snippet NICHT geladen.

handle /whisper/* {
	uri strip_prefix /whisper
	reverse_proxy filehub-whisper-asr:9000
}
