TZ=Europe/Berlin
PUID=1000
PGID=1000

PAPERLESS_PORT=8000
CONVERTX_PORT=3000
HOMEPAGE_PORT=3001
UPTIME_KUMA_PORT=3002
FILEBROWSER_PORT=3003
STIRLING_PDF_PORT=3004
DOZZLE_PORT=9999

PAPERLESS_SECRET_KEY=change-me-generate-random
PAPERLESS_ADMIN_USER=sebastian
PAPERLESS_ADMIN_PASSWORD=change-me
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=change-me
POSTGRES_PASSWORD=change-me

CONVERTX_JWT_SECRET=change-me-generate-random
ACCOUNT_REGISTRATION=false
CONVERTX_ALLOW_UNAUTHENTICATED=false
CONVERTX_HTTP_ALLOWED=true
CONVERTX_AUTO_DELETE_EVERY_N_HOURS=24
CONVERTX_HIDE_HISTORY=false
CONVERTX_LANGUAGE=de
CONVERTX_FFMPEG_ARGS=""
# Hinweis: ConvertX setzt FFMPEG_ARGS VOR `-i`. `-preset` bricht damit Audio.

# Filebrowser- und Stirling-Login-Variablen liegen NICHT hier, sondern in:
#   .secrets/filebrowser.env       (Mode 600)
#   .secrets/stirling-pdf.env      (Mode 600)
# Beide Dateien sind gitignored.

RESTIC_REPOSITORY=
RESTIC_PASSWORD=
RCLONE_CONFIG_PATH=/home/sebastian/.config/rclone/rclone.conf
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=6

# Optional proxy phase. Keep disabled until domains, HTTPS and auth are planned.
CADDY_HTTP_BIND=127.0.0.1
CADDY_HTTPS_BIND=127.0.0.1
CADDY_HTTP_PORT=8081
CADDY_HTTPS_PORT=8443

# Authentik SSO Gateway (Phase 1, lokal/privat) - default DEAKTIVIERT.
# Setze AUTHENTIK_ENABLED=true erst nach bewusster Aktivierung (docs/AUTHENTIK_OPTIONAL.md).
AUTHENTIK_ENABLED=false
AUTHENTIK_PORT=9000
FILEHUB_GATEWAY_PORT=3080
# DB-/Redis-Container fuer scripts/backup.sh (Defaults kompatibel zu compose.auth.yml).
AUTHENTIK_DB_HOST=filehub-authentik-db
AUTHENTIK_DB_PORT=5432
AUTHENTIK_DB_USER=authentik
AUTHENTIK_DB_NAME=authentik
AUTHENTIK_REDIS_CONTAINER=filehub-authentik-redis
# Secrets fuer Authentik liegen in .secrets/authentik.env (Mode 600).

# Zentraler lokaler Admin-Account (Single-User-Setup).
# Apps mit ENV-basierter Initial-Admin-Unterstuetzung sollen diese Werte verwenden.
# Reales Passwort NICHT ins Repo - in .env oder .secrets/*.env setzen.
FILEHUB_ADMIN_USER=admin
FILEHUB_ADMIN_PASSWORD=<set-local-secret>
FILEHUB_ADMIN_EMAIL=admin@filehub.local
