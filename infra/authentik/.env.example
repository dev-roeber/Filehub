# Authentik - app-spezifische Variablen.
# Secrets (AUTHENTIK_SECRET_KEY, AUTHENTIK_BOOTSTRAP_PASSWORD, _TOKEN) gehoeren in
# .secrets/authentik.env (Mode 600) und werden ueber env_file referenziert.

AUTHENTIK_ENABLED=false
AUTHENTIK_PORT=9000

# DB-/Redis-Parametrisierung (genutzt von scripts/backup.sh).
# Defaults sind kompatibel zu infra/authentik/compose.yml und compose.auth.yml.
AUTHENTIK_DB_HOST=filehub-authentik-db
AUTHENTIK_DB_PORT=5432
AUTHENTIK_DB_USER=authentik
AUTHENTIK_DB_NAME=authentik
AUTHENTIK_REDIS_CONTAINER=filehub-authentik-redis

# In .secrets/authentik.env (NICHT hier committen):
#   AUTHENTIK_SECRET_KEY=<set-local-secret>
#   AUTHENTIK_BOOTSTRAP_PASSWORD=<set-local-secret>
#   AUTHENTIK_BOOTSTRAP_TOKEN=<set-local-secret>
#   POSTGRES_PASSWORD=<set-local-secret>
#   AUTHENTIK_POSTGRESQL__PASSWORD=<set-local-secret>
