{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "schedule": ["after 6am and before 10am on monday"],
  "prHourlyLimit": 2,
  "dependencyDashboard": true,
  "docker-compose": {
    "enabled": true,
    "fileMatch": ["(^|/)compose[^/]*\\.ya?ml$"]
  },
  "pin": false,
  "digest": {
    "enabled": false
  },
  "labels": ["dependencies", "renovate"]
}
